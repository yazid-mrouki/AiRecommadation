# Modèle de configuration — COPIE ce fichier en ".env" puis mets ta vraie valeur.
# Le fichier .env est ignoré par git (voir .gitignore) : il ne sera jamais poussé.
# NE METS PAS de vrai token dans CE fichier-ci (.env.example est versionné).

# ============================================================================
# CERVEAU LLM (optionnel). Le moteur fonctionne sans. Renseigne UNE option :
# ============================================================================

# (A) RECOMMANDE POUR UNE SOCIETE : LLM auto-heberge -> PRIVE, ILLIMITE, GRATUIT.
#     Installe Ollama (https://ollama.com) sur ton serveur, puis :  ollama pull qwen2.5:7b
#     Le notebook l'utilise EN PRIORITE. Aucune donnee ne sort de l'entreprise.
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_MODEL=qwen2.5:7b

# (B) Cle API gratuite (plus fluide que HF pour enchainer beaucoup de produits) :
# GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxx
# GEMINI_API_KEY=AIxxxxxxxxxxxxxxxxxxxx

# (C) Hugging Face (deja la) : marche, mais l'API gratuite limite les rafales.
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# (D) Payant (meilleure qualite) :
# ANTHROPIC_API_KEY=sk-ant-xxxx
# OPENAI_API_KEY=sk-xxxx
